{
  "name": "browser-agent-service-admin-panel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "dev": "rsbuild dev",
    "build": "npm run generate-routes && rsbuild build",
    "start": "concurrently 'npm run watch-routes' 'npm run dev'",
    "preview": "rsbuild preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@rsbuild/plugin-react": "^1.4.6",
    "@rsbuild/plugin-styled-components": "^1.6.1",
    "@salutejs/plasma-icons": "^1.233.0",
    "@salutejs/sdds-platform-ai": "^0.347.0-next-platform-ai.0",
    "@tanstack/react-query": "^5.51.1",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-table": "^8.21.3",
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "styled-components": "^5.3.1"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-eslint": "^1.3.0",
    "@rsbuild/plugin-svgr": "^1.3.1",
    "@tanstack/router-cli": "^1.166.25",
    "@tanstack/router-plugin": "^1.167.12",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
